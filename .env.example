# ================================================================
# .env.example  —  Template for SMTP credentials
# ================================================================
# Is file ko `.env` ke naam se copy karein aur apni values bharein.
#   cp .env.example .env       (Linux/Mac)
#   copy .env.example .env     (Windows)
# ================================================================

# SMTP Server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# Account credentials (Gmail walon ke liye App Password chahiye)
SMTP_USER=andrewk808080@gmail.com
SMTP_PASSWORD=

# Sender identity
SMTP_FROM_NAME=Andrew Khan
SMTP_FROM_EMAIL=your.email@gmail.com
